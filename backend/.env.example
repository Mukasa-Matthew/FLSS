PORT=5000
# With docker-compose backend using network_mode:host (Linux), Postgres on the VPS is 127.0.0.1.
# Put your real DB password here; URL-encode special characters if needed (@ → %40, etc.).
DATABASE_URL=postgresql://flss_user:YOUR_DB_PASSWORD@127.0.0.1:5432/filesharing
CORS_ORIGIN=*
MAX_FILE_SIZE_BYTES=104857600
STREAM_BUFFER_BYTES=262144
DELETE_WINDOW_MINUTES=2
# JSON array of { "username", "password" } for download auth — use strong unique passwords in production.
DOWNLOAD_USERS_JSON="[{\"username\":\"user1\",\"password\":\"change-me\"},{\"username\":\"user2\",\"password\":\"change-me\"}]"
