PORT=5000
# From inside Docker, use host.docker.internal to reach Postgres on the VPS (not "localhost").
# Encode special characters in the password for URLs if needed.
DATABASE_URL=postgresql://flss_user:YOUR_PASSWORD@host.docker.internal:5432/filesharing
CORS_ORIGIN=*
MAX_FILE_SIZE_BYTES=104857600
STREAM_BUFFER_BYTES=262144
DELETE_WINDOW_MINUTES=2
DOWNLOAD_USERS_JSON="[{\"username\":\"Ocen\",\"password\":\"12345\"},{\"username\":\"Liz\",\"password\":\"54321\"},{\"username\":\"Matt\",\"password\":\"1100211Matt.\"},{\"username\":\"Mwiza\",\"password\":\"Mwiza\"}]"
